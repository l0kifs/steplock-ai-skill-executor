{
    "servers": {
        "steplock-dev": {
            "type": "stdio",
            "command": "uv",
            "args": [
                "run",
                "python",
                "-m",
                "steplock.entry_points.main"
            ],
            "cwd": "${workspaceFolder}"
        },
        "steplock-prod": {
            "type": "stdio",
            "command": "uvx",
            "args": [
                "steplock"
            ]
        }
    }
}